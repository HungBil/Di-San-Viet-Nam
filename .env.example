# OpenAI / Agent
OPENAI_API_KEY=
LLM_MODEL=gpt-4o-mini

# Public host ports
FRONTEND_PORT=5173
BACKEND_PORT=3000
AGENT_PORT=8000

# Frontend browser -> Backend
VITE_API_BASE_URL=http://localhost:3000

# Backend -> Agent
# Use http://agent:8000 inside Docker Compose.
# Use http://localhost:8000 when running backend locally without Docker.
AGENT_BASE_URL=http://agent:8000

# Public URL used when backend creates share links
APP_PUBLIC_URL=http://localhost:5173
